##############################################################
# BETSALEEL MUKUBA PORTFOLIO — Laravel Environment Config
# Copy this file to .env and fill in your real values
# NEVER commit your real .env to GitHub!
##############################################################

APP_NAME="Betsaleel Mukuba Portfolio"
APP_ENV=production
APP_KEY=base64:GENERATE_WITH_php_artisan_key:generate
APP_DEBUG=false
APP_URL=https://yourdomain.com

LOG_CHANNEL=stack
LOG_LEVEL=error

#────────────────────────────────────────────
# MAIL CONFIGURATION — Gmail SMTP
# To get Gmail App Password:
#  1. Go to myaccount.google.com/security
#  2. Enable 2-Step Verification
#  3. App Passwords → Select "Mail" → Generate
#  4. Copy the 16-character code below
#────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=mukuba950@gmail.com
MAIL_PASSWORD=your_16_char_app_password_here
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=mukuba950@gmail.com
MAIL_FROM_NAME="Betsaleel Mukuba"

# Email where contact form notifications are sent
OWNER_EMAIL=mukuba950@gmail.com

#────────────────────────────────────────────
# DATABASE (only needed if you add more features)
#────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=portfolio
DB_USERNAME=root
DB_PASSWORD=

#────────────────────────────────────────────
# CACHE / SESSION
#────────────────────────────────────────────
CACHE_DRIVER=file
SESSION_DRIVER=file
QUEUE_CONNECTION=sync
